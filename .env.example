# ─── Uygulama ─────────────────────────────────────────────────────────────
APP_ENV=dev
APP_SECRET=change_me_in_production_must_be_32_chars

# ─── JWT (firebase/php-jwt) ───────────────────────────────────────────────
# Token imzalama gizli anahtarı (HS256). Üretimde MUTLAKA değiştirin.
JWT_SECRET=dev_jwt_secret_change_me_in_production_0123456789abcdef
# Token geçerlilik süresi (saniye).
JWT_TTL=3600

# ─── Portlar ──────────────────────────────────────────────────────────────
HTTP_PORT=8080
ANGULAR_PORT=4200
POSTGRES_PORT=5432
REDIS_PORT=6379
MAILHOG_SMTP_PORT=1025
MAILHOG_HTTP_PORT=8025
PGADMIN_PORT=5050

# ─── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=secret

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=secret

# ─── pgAdmin ──────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@kurumsal.com
PGADMIN_PASSWORD=admin
